# Tick3t — environment config
# Copy to ".env" and fill in values (same hub as RedFace Pay).
# On Vercel: Project → Settings → Environment Variables → Production

# REQUIRED — Supabase hub (same as RedFace Pay)
# Without these, Pay SSO return tokens cannot create a session.
# Hub project ref: bpzzgilwlkghgfkvkkxx
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional — Clerk UI only (Tick3t auth is Pay ecosystem SSO → Supabase session)
# VITE_CLERK_PUBLISHABLE_KEY=

# Canonical site URL — approved satellite domain for Pay return_url
# Allowed: tick3t.online, www.tick3t.online, tick3t.vercel.app, *.vercel.app, localhost
VITE_SITE_URL=https://www.tick3t.online

# RedFace Pay origin (ecosystem login + checkout)
VITE_REDFACE_PAY_ORIGIN=https://www.redfacepay.co.za
