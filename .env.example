# Tick3t — environment config
# Copy to ".env" and fill in values (same hub as RedFace Pay).

# Supabase hub (Project Settings → API)
# Hub project ref: bpzzgilwlkghgfkvkkxx
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Clerk (same app as RedFace Pay)
# Add tick3t.online + *.vercel.app as allowed origins in Clerk Dashboard
VITE_CLERK_PUBLISHABLE_KEY=

# Canonical site URL — must be an approved satellite domain for Pay SSO return_url
# Allowed: tick3t.online, www.tick3t.online, tick3t.vercel.app, *.vercel.app, localhost
VITE_SITE_URL=https://www.tick3t.online

# Where Buy redirects for Paystack checkout + ecosystem login
VITE_REDFACE_PAY_ORIGIN=https://www.redfacepay.co.za
